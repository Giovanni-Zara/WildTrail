# Built application files
*.apk
*.aab
*.aar
*.ap_
*.dex

# Gradle & build output (regenerated on every build — never commit)
.gradle/
build/
app/build/
/captures
.externalNativeBuild/
.cxx/

# Local configuration & secrets — NEVER commit these
local.properties
app/google-services.json
*.keystore
*.jks
# Firebase Admin SDK service-account keys (full admin access — NEVER commit)
serviceAccount.json
**/serviceAccount*.json
*-firebase-adminsdk-*.json
# Demo seed media you may add locally
backend/seed_assets/avatars/*
backend/seed_assets/photos/*
backend/seed_assets/audio/*
!backend/seed_assets/**/.gitkeep
!backend/seed_assets/README.md

# Android Studio / IntelliJ IDEA (machine-specific)
*.iml
.idea/caches/
.idea/libraries/
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.idea/deploymentTargetSelector.xml
.idea/deploymentTargetDropDown.xml

# Kotlin
.kotlin/

